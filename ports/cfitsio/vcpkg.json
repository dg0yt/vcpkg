{
  "name": "cfitsio",
  "version": "4.1.0",
  "description": "Library of C and Fortran subroutines for reading and writing data files in FITS (Flexible Image Transport System) data format",
  "homepage": "https://heasarc.gsfc.nasa.gov/fitsio/",
  "license": null,
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "zlib"
  ],
  "features": {
    "curl": {
      "description": "Enable remote file drivers (using CURL)",
      "dependencies": [
        {
          "name": "curl",
          "default-features": false
        }
      ],
      "supports": "!windows"
    },
    "pthreads": {
      "description": "Thread-safe build (using pthreads)",
      "dependencies": [
        {
          "name": "pthreads",
          "platform": "windows & !mingw"
        }
      ]
    },
    "tools": {
      "description": "Build FPack, Funpack, and Fitscopy executables"
    }
  }
}
